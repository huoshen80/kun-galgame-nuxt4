{
  "name": "kun-galgame-nuxt4-fiber",
  "version": "5.1.3",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -F \"./apps/**\" --parallel --stream run dev",
    "build": "pnpm -F \"./apps/**\" --parallel run build",
    "format": "pnpm -F \"./apps/**\" --parallel run format",
    "lint": "pnpm -F \"./apps/web\" run lint",
    "lint:fix": "pnpm -F \"./apps/web\" run lint:fix",
    "typecheck": "pnpm -F \"./apps/web\" run typecheck",
    "prepare": "husky",
    "precommit": "node .husky/scripts/bumpAppVersion.js && git add package.json",
    "sitemap": "esno apps/web/scripts/generateSitemap.ts",
    "prod:deploy": "./scripts/deploy.sh",
    "pm2:start": "./scripts/start.sh",
    "pm2:stop": "./scripts/stop.sh",
    "pm2:restart": "pm2 restart kun-galgame-nuxt",
    "pm2:logs": "pm2 logs"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "esno": "^4.8.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "is-arguments": "npm:@nolyfill/is-arguments@^1",
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "is-generator-function": "npm:@nolyfill/is-generator-function@^1",
      "is-typed-array": "npm:@nolyfill/is-typed-array@^1",
      "isarray": "npm:@nolyfill/isarray@^1",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1",
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1",
      "string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1",
      "which-typed-array": "npm:@nolyfill/which-typed-array@^1",
      "prosemirror-model": "1.25.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "aws-sdk",
      "bcrypt",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "puppeteer",
      "vue-demi"
    ]
  }
}
